        "DISPATCH": "resolution",
        "NUM_PASSES": 3
    },
    "INPUTS": [
        {"NAME": "growth",       "TYPE": "float", "DEFAULT": 1.0,   "MIN": 0.0,  "MAX": 2.0,   "LABEL": "Structure Growth"},
        {"NAME": "evolve",       "TYPE": "float", "DEFAULT": 0.6,   "MIN": 0.0,  "MAX": 1.0,   "LABEL": "Auto Evolve"},
        {"NAME": "evolve_speed", "TYPE": "float", "DEFAULT": 0.2,   "MIN": 0.0,  "MAX": 2.0,   "LABEL": "Evolve Speed"},
        {"NAME": "web_scale",    "TYPE": "float", "DEFAULT": 4.0,   "MIN": 1.0,  "MAX": 16.0,  "LABEL": "Web Scale"},
        {"NAME": "tilt",         "TYPE": "float", "DEFAULT": 0.965, "MIN": 0.7,  "MAX": 1.2,   "LABEL": "Spectral Index"},
        {"NAME": "kmax",         "TYPE": "float", "DEFAULT": 32.0,  "MIN": 8.0,  "MAX": 64.0,  "LABEL": "Detail (k-max)"},
        {"NAME": "seed",         "TYPE": "float", "DEFAULT": 0.0,   "MIN": 0.0,  "MAX": 100.0, "LABEL": "Realization Seed"},
        {"NAME": "density_gain", "TYPE": "float", "DEFAULT": 2.0,   "MIN": 0.1,  "MAX": 8.0,   "LABEL": "Density Gain"},
