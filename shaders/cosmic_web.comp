        {"NAME": "void_color",     "TYPE": "color", "DEFAULT": [0.04, 0.02, 0.10, 1.0], "LABEL": "Void Color"},
        {"NAME": "filament_color", "TYPE": "color", "DEFAULT": [0.45, 0.25, 0.75, 1.0], "LABEL": "Filament Color"},
